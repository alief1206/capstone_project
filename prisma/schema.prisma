generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Goal {
  LOSE_WEIGHT
  GAIN_WEIGHT
  MAINTAIN
}

model User {
  id            Int        @id @default(autoincrement())
  name          String
  email         String     @unique
  password      String
  age           Int?
  height        Float?     // Dalam cm
  currentWeight Float?     // Dalam kg
  targetWeight  Float?     // Dalam kg
  goal          Goal?
  createdAt     DateTime   @default(now())
  foodLogs      FoodLog[]
}

model FoodLog {
  id          Int      @id @default(autoincrement())
  userId      Int
  foodName    String
  calories    Float?
  aiAnalysis  String?  @db.Text
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}